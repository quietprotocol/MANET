#!/bin/bash
# networkd-dispatcher hook for br0 events
# Used when end0 IS a bridge member
# Only triggers if end0 state actually changed

TARGET_IFACE="end0"
BRIDGE_IFACE="br0"
STATE_FILE="/var/run/end0_carrier_state"

echo "[$(date +'%Y-%m-%d %H:%M:%S')] - CARRIER-BRIDGE: Called for IFACE=$IFACE" >> /var/log/carrier-hook.log

# Only process br0 events
if [ "$IFACE" != "$BRIDGE_IFACE" ]; then
    exit 0
fi

# Check if end0 is a bridge member
if ! bridge link show | grep -q "$TARGET_IFACE"; then
    echo "[$(date +'%Y-%m-%d %H:%M:%S')] - CARRIER-BRIDGE: $TARGET_IFACE not a bridge member, skipping" >> /var/log/carrier-hook.log
    exit 0
fi

# Get current end0 carrier state
CURRENT_CARRIER=$(cat /sys/class/net/$TARGET_IFACE/carrier 2>/dev/null || echo 0)

# Get previous state
PREVIOUS_CARRIER="unknown"
if [ -f "$STATE_FILE" ]; then
    PREVIOUS_CARRIER=$(cat "$STATE_FILE")
fi

# Update state file
echo "$CURRENT_CARRIER" > "$STATE_FILE"

# Only run detection if state CHANGED
if [ "$CURRENT_CARRIER" != "$PREVIOUS_CARRIER" ]; then
    echo "[$(date +'%Y-%m-%d %H:%M:%S')] - CARRIER-BRIDGE: $TARGET_IFACE carrier changed: $PREVIOUS_CARRIER -> $CURRENT_CARRIER" >> /var/log/carrier-hook.log
    
    if [ "$CURRENT_CARRIER" == "1" ]; then
        echo "[$(date +'%Y-%m-%d %H:%M:%S')] - CARRIER-BRIDGE: Running detection for $TARGET_IFACE" >> /var/log/carrier-hook.log
        /usr/local/bin/ethernet-autodetect.sh
    else
        echo "[$(date +'%Y-%m-%d %H:%M:%S')] - CARRIER-BRIDGE: Cable unplugged, detection will run via off.d hook" >> /var/log/carrier-hook.log
    fi
else
    echo "[$(date +'%Y-%m-%d %H:%M:%S')] - CARRIER-BRIDGE: $TARGET_IFACE carrier unchanged ($CURRENT_CARRIER), skipping" >> /var/log/carrier-hook.log
fi

exit 0
